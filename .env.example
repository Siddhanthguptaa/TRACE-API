# TRACE API Environment Variables
# Copy to .env and fill in your values. NEVER commit .env to git.

# Database 
# Defaults to local SQLite if left empty. Use a PostgreSQL URL for production.
# Example: postgresql+asyncpg://user:pass@host:5432/trace
DATABASE_URL=sqlite+aiosqlite:///./trace.db

# Supabase Auth (required — app will not start without these)
# Get these from your Supabase project dashboard → Settings → API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_KEY=your_supabase_anon_key_here
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Razorpay Billing Integration
RAZORPAY_KEY_ID=rzp_test_your_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_secret_here
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

# Rate Limiting
RATE_LIMIT_DEFAULT=60/minute
RATE_LIMIT_AUTH=10/minute
RATE_LIMIT_EVENTS=120/minute
RATE_LIMIT_BENCHMARK=5/minute

# Redis & Celery
CELERY_BROKER_URL=redis://localhost:6379/0
REDIS_URL=redis://localhost:6379/1

# ── Frontend (web/.env.local) ──────────────────────────────────────────────────
# These NEXT_PUBLIC_ vars must be set in web/.env.local (NOT in this root .env).
# They are baked into the Next.js build at compile time.
#
# NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
# NEXT_PUBLIC_API_URL=http://localhost:8000
